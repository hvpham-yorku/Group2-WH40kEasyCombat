<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeTableColumn?>
<?import javafx.scene.control.TreeTableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0"
            prefWidth="1200.0"
            styleClass="army-root"
            stylesheets="@application.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="eecs2311.group2.wh40k_easycombat.controller.ArmyController">

    <padding>
        <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
    </padding>

    <left>
        <VBox prefWidth="350.0" spacing="14.0" styleClass="army-left-panel" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="12.0" styleClass="army-card, army-filter-card">
                    <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                    </padding>

                    <children>
                        <Label styleClass="army-card-title" text="Select Faction">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>

                        <ComboBox fx:id="factionCBbox"
                                  prefHeight="42.0"
                                  prefWidth="318.0"
                                  styleClass="ds-combo" />
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="army-card, army-unit-select-card" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                    </padding>

                    <children>
                        <Label styleClass="army-card-title" text="Select Unit">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>

                        <TreeTableView fx:id="unitSectionTreeTable"
                                       minHeight="0.0"
                                       prefHeight="620.0"
                                       prefWidth="318.0"
                                       styleClass="game-table"
                                       VBox.vgrow="ALWAYS">
                            <columns>
                                <TreeTableColumn fx:id="selectUnit" editable="false" prefWidth="236.0" text="Units" />
                                <TreeTableColumn fx:id="selectPoint" prefWidth="80.0" text="Cost" />
                            </columns>
                        </TreeTableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Button fx:id="addButton"
                                        mnemonicParsing="false"
                                        onMouseClicked="#add"
                                        prefHeight="40.0"
                                        prefWidth="110.0"
                                        styleClass="wh-btn, wh-btn-primary"
                                        text="Add">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <HBox spacing="14.0" BorderPane.alignment="CENTER">
            <children>
                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                    <VBox spacing="12.0" styleClass="army-card, army-list-shell" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                        </padding>

                        <children>
                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                <children>
                                    <Label styleClass="army-card-title" text="Current Army">
                                        <font>
                                            <Font name="System Bold" size="18.0" />
                                        </font>
                                    </Label>

                                    <Region HBox.hgrow="ALWAYS" />

                                    <Label styleClass="army-section-title" text="Battle Size">
                                        <font>
                                            <Font size="16.0" />
                                        </font>
                                    </Label>

                                    <ComboBox fx:id="sizeCBbox"
                                              prefHeight="36.0"
                                              prefWidth="140.0"
                                              promptText="2000"
                                              styleClass="ds-combo" />

                                    <Button fx:id="importButton"
                                            mnemonicParsing="false"
                                            onMouseClicked="#importData"
                                            prefHeight="40.0"
                                            prefWidth="150.0"
                                            styleClass="wh-btn"
                                            text="Import From Clipboard"
                                            wrapText="true">
                                        <font>
                                            <Font size="13.0" />
                                        </font>
                                    </Button>
                                </children>
                            </HBox>

                            <ListView fx:id="armyList"
                                      minHeight="0.0"
                                      prefHeight="620.0"
                                      prefWidth="520.0"
                                      styleClass="game-list, army-army-list"
                                      VBox.vgrow="ALWAYS" />

                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                <children>
                                    <Button fx:id="removeButton"
                                            mnemonicParsing="false"
                                            onMouseClicked="#removeUnit"
                                            prefHeight="40.0"
                                            prefWidth="115.0"
                                            styleClass="wh-btn, wh-btn-danger"
                                            text="Remove">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Button>

                                    <Button fx:id="setWarlordButton"
                                            mnemonicParsing="false"
                                            onMouseClicked="#setWarlord"
                                            prefHeight="40.0"
                                            prefWidth="130.0"
                                            styleClass="wh-btn"
                                            text="Set Warlord">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Button>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </VBox>

                <VBox prefWidth="330.0" spacing="14.0">
                    <VBox spacing="12.0" styleClass="army-card, army-setup-card">
                        <padding>
                            <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                        </padding>

                        <children>
                            <Label styleClass="army-card-title" text="Army Setup">
                                <font>
                                    <Font name="System Bold" size="18.0" />
                                </font>
                            </Label>

                            <VBox spacing="8.0">
                                <children>
                                    <Label styleClass="army-section-title" text="Choose Your Detachment">
                                        <font>
                                            <Font size="16.0" />
                                        </font>
                                    </Label>
                                    <ComboBox fx:id="datachmentCBbox"
                                              prefHeight="38.0"
                                              prefWidth="298.0"
                                              styleClass="ds-combo" />
                                </children>
                            </VBox>

                            <VBox spacing="8.0">
                                <children>
                                    <Label styleClass="army-section-title" text="Name of Your Army">
                                        <font>
                                            <Font size="16.0" />
                                        </font>
                                    </Label>
                                    <TextField fx:id="armyNametxt"
                                               prefHeight="36.0"
                                               prefWidth="298.0"
                                               styleClass="ds-search">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </TextField>
                                </children>
                            </VBox>

                            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="army-points-row">
                                <children>
                                    <Label styleClass="army-section-title" text="Points">
                                        <font>
                                            <Font size="16.0" />
                                        </font>
                                    </Label>
                                    <Label fx:id="pointNumber"
                                           styleClass="army-points-value, army-points-chip"
                                           text="2000">
                                        <font>
                                            <Font name="System Bold" size="24.0" />
                                        </font>
                                    </Label>
                                </children>
                            </HBox>

                            <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                <children>
                                    <Button fx:id="saveButton"
                                            mnemonicParsing="false"
                                            onMouseClicked="#save"
                                            prefHeight="40.0"
                                            prefWidth="105.0"
                                            styleClass="wh-btn, wh-btn-primary"
                                            text="Save">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Button>

                                    <Button fx:id="CancelButton"
                                            mnemonicParsing="false"
                                            onMouseClicked="#cancelTheChange"
                                            prefHeight="40.0"
                                            prefWidth="105.0"
                                            styleClass="wh-btn, wh-btn-danger"
                                            text="Back">
                                        <font>
                                            <Font size="14.0" />
                                        </font>
                                    </Button>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox spacing="12.0" styleClass="army-card, army-saved-card" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                        </padding>

                        <children>
                            <Label styleClass="army-card-title" text="Saved Armies">
                                <font>
                                    <Font name="System Bold" size="18.0" />
                                </font>
                            </Label>

                            <TableView fx:id="savedArmyTable"
                                       minHeight="0.0"
                                       prefHeight="360.0"
                                       prefWidth="298.0"
                                       styleClass="game-table"
                                       VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="savedName" prefWidth="208.0" text="Army Name" />
                                    <TableColumn fx:id="savedPoint" prefWidth="88.0" text="Points" />
                                </columns>
                            </TableView>

                            <HBox alignment="CENTER_RIGHT" spacing="8.0">
                                <children>
                                    <Button fx:id="favoriteButton"
                                            mnemonicParsing="false"
                                            onMouseClicked="#favorite"
                                            prefHeight="34.0"
                                            prefWidth="84.0"
                                            styleClass="wh-btn"
                                            text="Favorite" />

                                    <Button fx:id="deleteButton"
                                            mnemonicParsing="false"
                                            onMouseClicked="#delete"
                                            prefHeight="34.0"
                                            prefWidth="80.0"
                                            styleClass="wh-btn, wh-btn-danger"
                                            text="Delete" />

                                    <Button fx:id="loadButton"
                                            mnemonicParsing="false"
                                            onMouseClicked="#loadArmy"
                                            prefHeight="34.0"
                                            prefWidth="72.0"
                                            styleClass="wh-btn, wh-btn-primary"
                                            text="Load" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </VBox>
            </children>
        </HBox>
    </center>
</BorderPane>
