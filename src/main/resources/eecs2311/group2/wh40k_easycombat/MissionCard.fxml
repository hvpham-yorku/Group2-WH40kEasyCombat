<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0"
            prefWidth="860.0"
            styleClass="game-root"
            stylesheets="@application.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="eecs2311.group2.wh40k_easycombat.controller.MissionCardController">

    <top>
        <VBox fx:id="headerBox" spacing="8.0" styleClass="mission-header-box" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18.0" right="24.0" bottom="18.0" left="24.0" />
            </padding>
            <children>
                <Label fx:id="missionTypeLabel" styleClass="mission-type-label" text="PRIMARY MISSION">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Label fx:id="missionTitleLabel" text="MISSION TITLE" wrapText="true">
                    <font>
                        <Font name="System Bold" size="34.0" />
                    </font>
                </Label>
                <Label fx:id="missionContextLabel" text="" wrapText="true" />
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="18.0" styleClass="mission-card-body">
                    <padding>
                        <Insets top="18.0" right="24.0" bottom="18.0" left="24.0" />
                    </padding>
                    <children>
                        <Label fx:id="missionIntroLabel" styleClass="mission-intro-label" text="Mission intro" wrapText="true" />
                        <VBox fx:id="missionBodyBox" spacing="14.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="12.0" styleClass="mission-footer-bar" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="0.0" right="24.0" bottom="18.0" left="24.0" />
            </padding>
            <children>
                <VBox spacing="8.0">
                    <children>
                        <Label text="Award VP To" />
                        <ComboBox fx:id="awardedPlayerComboBox" prefWidth="150.0" styleClass="game-combo" />
                    </children>
                </VBox>
                <VBox spacing="8.0">
                    <children>
                        <Label text="VP Preset" />
                        <ComboBox fx:id="vpPresetComboBox" prefWidth="120.0" styleClass="game-combo" />
                    </children>
                </VBox>
                <VBox spacing="8.0">
                    <children>
                        <Label text="Custom VP" />
                        <TextField fx:id="customVpField" prefWidth="110.0" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="closeButton"
                        mnemonicParsing="false"
                        onAction="#closeOnly"
                        styleClass="wh-btn"
                        text="Close" />
                <Button fx:id="activeButton"
                        mnemonicParsing="false"
                        onAction="#markNotCompleted"
                        prefWidth="120.0"
                        styleClass="wh-btn"
                        text="Keep Open"
                        wrapText="true" />
                <Button fx:id="completeButton"
                        mnemonicParsing="false"
                        onAction="#markCompleted"
                        prefWidth="170.0"
                        styleClass="wh-btn, wh-btn-primary"
                        text="Complete + Add VP"
                        wrapText="true" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
