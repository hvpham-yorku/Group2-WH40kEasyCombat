<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="860.0"
            prefWidth="1480.0"
            styleClass="game-root"
            stylesheets="@application.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="eecs2311.group2.wh40k_easycombat.controller.RuleEditorController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16.0" right="18.0" bottom="16.0" left="18.0" />
            </padding>
            <children>
                <Label text="Custom Rule Editor">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" text="Create or edit enabled custom rules for Auto Battle." wrapText="true" />
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="330.0" spacing="12.0" styleClass="game-side-panel" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
            </padding>
            <children>
                <Label text="Saved Rules">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <ListView fx:id="rulesListView" prefHeight="640.0" VBox.vgrow="ALWAYS" />
                <Button fx:id="newRuleButton"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#newRule"
                        styleClass="wh-btn, wh-btn-primary"
                        text="New Rule" />
                <Button fx:id="deleteRuleButton"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#deleteRule"
                        styleClass="wh-btn"
                        text="Delete Selected Rule" />
                <Button fx:id="backButton"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#back"
                        styleClass="wh-btn"
                        text="Back To Datasheets" />
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="16.0" styleClass="game-center-panel">
                    <padding>
                        <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                    </padding>
                    <children>
                        <Label fx:id="helperLabel"
                               style="-fx-font-size: 14px;"
                               text="Enabled custom rules auto-apply in Auto Battle whenever their phase, attack type and bindings match. If a triggering stratagem name is set, using that stratagem will prompt for one affected unit and apply the rule for the chosen duration."
                               wrapText="true" />

                        <VBox spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Identity">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <GridPane hgap="12.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Rule Name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Rule Type" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <ComboBox fx:id="typeComboBox"
                                                  maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="3"
                                                  GridPane.rowIndex="0" />

                                        <Label text="Activation" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="activationModeComboBox"
                                                  maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="1" />
                                        <Label text="Phase" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="phaseComboBox"
                                                  maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="3"
                                                  GridPane.rowIndex="1" />

                                        <Label text="Attack Type" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <ComboBox fx:id="attackTypeComboBox"
                                                  maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="2" />
                                        <CheckBox fx:id="enabledCheckBox"
                                                  styleClass="game-checkbox"
                                                  text="Enabled"
                                                  GridPane.columnIndex="3"
                                                  GridPane.rowIndex="2" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Who This Rule Matches">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <GridPane hgap="12.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Attacker Name Contains" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="attackerUnitNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Defender Name Contains" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <TextField fx:id="defenderUnitNameField" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                        <Label text="Attacker Required Keyword" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="attackerKeywordField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Defender Required Keyword" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <TextField fx:id="defenderKeywordField" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                        <Label text="Attacker Skill Contains" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="attackerAbilityField" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label text="Defender Skill Contains" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                        <TextField fx:id="defenderAbilityField" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                                        <Label text="Attacker Faction Ability Contains" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <TextField fx:id="attackerFactionAbilityField" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Label text="Defender Faction Ability Contains" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                        <TextField fx:id="defenderFactionAbilityField" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                                        <Label text="Attacker Detachment Ability Contains" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <TextField fx:id="attackerDetachmentAbilityField" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                        <Label text="Defender Detachment Ability Contains" GridPane.columnIndex="2" GridPane.rowIndex="4" />
                                        <TextField fx:id="defenderDetachmentAbilityField" GridPane.columnIndex="3" GridPane.rowIndex="4" />

                                        <Label text="Attacker Faction Contains" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                        <TextField fx:id="attackerFactionField" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                        <Label text="Defender Faction Contains" GridPane.columnIndex="2" GridPane.rowIndex="5" />
                                        <TextField fx:id="defenderFactionField" GridPane.columnIndex="3" GridPane.rowIndex="5" />

                                        <Label text="Attacker Detachment Contains" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                        <TextField fx:id="attackerDetachmentField" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                                        <Label text="Defender Detachment Contains" GridPane.columnIndex="2" GridPane.rowIndex="6" />
                                        <TextField fx:id="defenderDetachmentField" GridPane.columnIndex="3" GridPane.rowIndex="6" />

                                        <Label text="Attacker Enhancement Contains" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                        <TextField fx:id="attackerEnhancementField" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                                        <Label text="Defender Enhancement Contains" GridPane.columnIndex="2" GridPane.rowIndex="7" />
                                        <TextField fx:id="defenderEnhancementField" GridPane.columnIndex="3" GridPane.rowIndex="7" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Stratagem Trigger">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <GridPane hgap="12.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Triggering Stratagem Contains" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="triggeringStratagemField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Affected Unit Role" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <ComboBox fx:id="targetRoleComboBox"
                                                  maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="3"
                                                  GridPane.rowIndex="0" />

                                        <Label text="Bonus Duration" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="durationComboBox"
                                                  maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="1" />
                                        <Label text="Leave stratagem empty to make this a passive auto-applied rule."
                                               wrapText="true"
                                               GridPane.columnIndex="2"
                                               GridPane.columnSpan="2"
                                               GridPane.rowIndex="1" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Conditions">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <HBox spacing="22.0" fillHeight="true">
                                    <children>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <CheckBox fx:id="requireHalfRangeCheckBox" styleClass="game-checkbox" text="Require Within Half Range" />
                                                <CheckBox fx:id="requireStationaryCheckBox" styleClass="game-checkbox" text="Require Remained Stationary" />
                                                <CheckBox fx:id="requireChargedCheckBox" styleClass="game-checkbox" text="Require Charged This Turn" />
                                                <CheckBox fx:id="requireTargetCoverCheckBox" styleClass="game-checkbox" text="Require Target Has Cover" />
                                            </children>
                                        </VBox>
                                        <Separator orientation="VERTICAL" />
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <CheckBox fx:id="requireInfantryCheckBox" styleClass="game-checkbox" text="Require Target Infantry" />
                                                <CheckBox fx:id="requireVehicleCheckBox" styleClass="game-checkbox" text="Require Target Vehicle" />
                                                <CheckBox fx:id="requireMonsterCheckBox" styleClass="game-checkbox" text="Require Target Monster" />
                                                <CheckBox fx:id="requireCharacterCheckBox" styleClass="game-checkbox" text="Require Target Character" />
                                                <CheckBox fx:id="requirePsykerCheckBox" styleClass="game-checkbox" text="Require Target Psyker" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Effects Applied To The Attack">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <GridPane hgap="12.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Hit Modifier" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="hitModifierField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Wound Modifier" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <TextField fx:id="woundModifierField" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                        <Label text="Attacks Modifier" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="attacksModifierField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Damage Modifier" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <TextField fx:id="damageModifierField" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                        <Label text="AP Modifier" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="apModifierField" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label text="Extra Weapon Keywords" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                        <TextField fx:id="extraKeywordsField" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                                        <Label text="Hit Re-roll" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <ComboBox fx:id="hitRerollComboBox"
                                                  maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="3" />
                                        <Label text="Wound Re-roll" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                        <ComboBox fx:id="woundRerollComboBox"
                                                  maxWidth="1.7976931348623157E308"
                                                  GridPane.columnIndex="3"
                                                  GridPane.rowIndex="3" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Notes">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <TextArea fx:id="notesTextArea"
                                          prefHeight="140.0"
                                          wrapText="true"
                                          VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button fx:id="saveRuleButton"
                                        mnemonicParsing="false"
                                        onAction="#saveRule"
                                        styleClass="wh-btn, wh-btn-primary"
                                        text="Save Rule" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
