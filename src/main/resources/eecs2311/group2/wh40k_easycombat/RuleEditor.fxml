<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0"
            prefWidth="1520.0"
            styleClass="game-root"
            stylesheets="@application.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="eecs2311.group2.wh40k_easycombat.controller.RuleEditorController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="editor-header-bar" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="16.0" right="18.0" bottom="16.0" left="18.0" />
            </padding>
            <children>
                <Label text="Custom Rule Editor (VM)">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" text="Create or edit VM-backed custom rules." wrapText="true" />
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="340.0" spacing="12.0" styleClass="game-side-panel" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
            </padding>
            <children>
                <Label text="Rule Library">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <ListView fx:id="rulesListView" prefHeight="680.0" VBox.vgrow="ALWAYS" />
                <Button fx:id="newRuleButton"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#newRule"
                        styleClass="wh-btn, wh-btn-primary"
                        text="New Rule" />
                <Button fx:id="deleteRuleButton"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#deleteRule"
                        styleClass="wh-btn"
                        text="Delete Selected Rule" />
                <Button fx:id="backButton"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#back"
                        styleClass="wh-btn"
                        text="Back To Datasheets" />
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="16.0" styleClass="game-center-panel">
                    <padding>
                        <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                    </padding>
                    <children>
                        <Label fx:id="helperLabel" style="-fx-font-size: 14px;" wrapText="true" />

                        <VBox fx:id="identityCard" spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Identity">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <GridPane hgap="12.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Rule Name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Rule Type" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <ComboBox fx:id="typeComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                        <Label text="Phase" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="phaseComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Attack Type" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="attackTypeComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                        <CheckBox fx:id="optionalActivationCheckBox"
                                                  styleClass="game-checkbox"
                                                  text="Optional Activation In Auto Battle"
                                                  GridPane.columnIndex="1"
                                                  GridPane.rowIndex="2" />
                                        <CheckBox fx:id="enabledCheckBox"
                                                  styleClass="game-checkbox"
                                                  text="Enabled"
                                                  GridPane.columnIndex="3"
                                                  GridPane.rowIndex="2" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox fx:id="matchCard" spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Who This Rule Matches">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <GridPane hgap="12.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Attacker Name Contains" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="attackerUnitNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Defender Name Contains" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <TextField fx:id="defenderUnitNameField" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                        <Label text="Weapon Name Contains" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <TextField fx:id="weaponNameField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Attacker Keyword" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <TextField fx:id="attackerKeywordField" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                                        <Label text="Defender Keyword" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <TextField fx:id="defenderKeywordField" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label text="Attacker Ability Contains" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                        <TextField fx:id="attackerAbilityField" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                                        <Label text="Defender Ability Contains" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <TextField fx:id="defenderAbilityField" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <Label text="Attacker Faction Ability Contains" GridPane.columnIndex="2" GridPane.rowIndex="3" />
                                        <TextField fx:id="attackerFactionAbilityField" GridPane.columnIndex="3" GridPane.rowIndex="3" />

                                        <Label text="Defender Faction Ability Contains" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                        <TextField fx:id="defenderFactionAbilityField" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                        <Label text="Attacker Detachment Ability Contains" GridPane.columnIndex="2" GridPane.rowIndex="4" />
                                        <TextField fx:id="attackerDetachmentAbilityField" GridPane.columnIndex="3" GridPane.rowIndex="4" />

                                        <Label text="Defender Detachment Ability Contains" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                        <TextField fx:id="defenderDetachmentAbilityField" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                        <Label text="Attacker Faction Contains" GridPane.columnIndex="2" GridPane.rowIndex="5" />
                                        <TextField fx:id="attackerFactionField" GridPane.columnIndex="3" GridPane.rowIndex="5" />

                                        <Label text="Defender Faction Contains" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                        <TextField fx:id="defenderFactionField" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                                        <Label text="Attacker Detachment Contains" GridPane.columnIndex="2" GridPane.rowIndex="6" />
                                        <TextField fx:id="attackerDetachmentField" GridPane.columnIndex="3" GridPane.rowIndex="6" />

                                        <Label text="Defender Detachment Contains" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                        <TextField fx:id="defenderDetachmentField" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                                        <Label text="Attacker Enhancement Contains" GridPane.columnIndex="2" GridPane.rowIndex="7" />
                                        <TextField fx:id="attackerEnhancementField" GridPane.columnIndex="3" GridPane.rowIndex="7" />

                                        <Label text="Defender Enhancement Contains" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                                        <TextField fx:id="defenderEnhancementField" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox fx:id="stratagemCard" spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Stratagem Trigger">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <GridPane hgap="12.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="20.0" />
                                        <ColumnConstraints percentWidth="30.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Triggering Stratagem Contains" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <TextField fx:id="triggeringStratagemField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Affected Unit Role" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <ComboBox fx:id="targetRoleComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                                        <Label text="Bonus Duration" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="durationComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="Leave the stratagem field empty to make this rule available as a passive or optional auto battle VM rule."
                                               wrapText="true"
                                               GridPane.columnIndex="2"
                                               GridPane.columnSpan="2"
                                               GridPane.rowIndex="1" />
                                        <Label text="Enable Optional Activation if this rule should appear as a selectable ability during auto battle for matching units and weapons."
                                               wrapText="true"
                                               GridPane.columnIndex="0"
                                               GridPane.columnSpan="4"
                                               GridPane.rowIndex="2" />
                                    </children>
                                </GridPane>
                            </children>
                        </VBox>

                        <VBox fx:id="visualLogicCard" spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Visual VM Logic">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <Label text="Select the conditions that must all be true before this rule applies." wrapText="true" />
                                <GridPane hgap="16.0" vgap="8.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="33.3" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="33.4" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <CheckBox fx:id="visualWithinHalfRangeCheckBox" styleClass="game-checkbox" text="Within Half Range" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <CheckBox fx:id="visualRemainedStationaryCheckBox" styleClass="game-checkbox" text="Remained Stationary" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <CheckBox fx:id="visualAdvancedThisTurnCheckBox" styleClass="game-checkbox" text="Advanced This Turn" GridPane.columnIndex="2" GridPane.rowIndex="0" />

                                        <CheckBox fx:id="visualFellBackThisTurnCheckBox" styleClass="game-checkbox" text="Fell Back This Turn" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <CheckBox fx:id="visualChargedThisTurnCheckBox" styleClass="game-checkbox" text="Charged This Turn" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <CheckBox fx:id="visualAttackerCanFightCheckBox" styleClass="game-checkbox" text="Attacker Can Fight" GridPane.columnIndex="2" GridPane.rowIndex="1" />

                                        <CheckBox fx:id="visualTargetHasCoverCheckBox" styleClass="game-checkbox" text="Target Has Cover" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <CheckBox fx:id="visualBlastIsLegalCheckBox" styleClass="game-checkbox" text="Blast Is Legal" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <CheckBox fx:id="visualTargetInfantryCheckBox" styleClass="game-checkbox" text="Target Is Infantry" GridPane.columnIndex="2" GridPane.rowIndex="2" />

                                        <CheckBox fx:id="visualTargetVehicleCheckBox" styleClass="game-checkbox" text="Target Is Vehicle" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                        <CheckBox fx:id="visualTargetMonsterCheckBox" styleClass="game-checkbox" text="Target Is Monster" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                        <CheckBox fx:id="visualTargetCharacterCheckBox" styleClass="game-checkbox" text="Target Is Character" GridPane.columnIndex="2" GridPane.rowIndex="3" />

                                        <CheckBox fx:id="visualTargetPsykerCheckBox" styleClass="game-checkbox" text="Target Is Psyker" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                    </children>
                                </GridPane>

                                <Label text="Choose the values this rule writes into the VM outputs." wrapText="true" />
                                <GridPane hgap="12.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints percentWidth="16.0" />
                                        <ColumnConstraints percentWidth="17.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="16.0" />
                                        <ColumnConstraints percentWidth="17.0" hgrow="ALWAYS" />
                                        <ColumnConstraints percentWidth="16.0" />
                                        <ColumnConstraints percentWidth="18.0" hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Hit Mod" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                        <Spinner fx:id="visualHitModifierSpinner" editable="true" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                        <Label text="Wound Mod" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                                        <Spinner fx:id="visualWoundModifierSpinner" editable="true" maxWidth="1.7976931348623157E308" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                                        <Label text="Attacks Mod" GridPane.columnIndex="4" GridPane.rowIndex="0" />
                                        <Spinner fx:id="visualAttacksModifierSpinner" editable="true" maxWidth="1.7976931348623157E308" GridPane.columnIndex="5" GridPane.rowIndex="0" />

                                        <Label text="Damage Mod" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                        <Spinner fx:id="visualDamageModifierSpinner" editable="true" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                        <Label text="AP Mod" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                                        <Spinner fx:id="visualApModifierSpinner" editable="true" maxWidth="1.7976931348623157E308" GridPane.columnIndex="3" GridPane.rowIndex="1" />
                                        <Label text="Hit Reroll" GridPane.columnIndex="4" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="visualHitRerollComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="5" GridPane.rowIndex="1" />

                                        <Label text="Wound Reroll" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                        <ComboBox fx:id="visualWoundRerollComboBox" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                        <Label text="Weapon Keywords" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                                        <TextField fx:id="visualKeywordsField" promptText="Example: ASSAULT, LANCE" GridPane.columnIndex="3" GridPane.columnSpan="3" GridPane.rowIndex="2" />
                                    </children>
                                </GridPane>

                                <HBox alignment="CENTER_RIGHT" spacing="12.0">
                                    <children>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="resetLogicButton"
                                                mnemonicParsing="false"
                                                onAction="#resetVisualLogic"
                                                styleClass="wh-btn"
                                                text="Reset Visual Logic" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="12.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label text="Generated VM Script">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <Label fx:id="scriptHelpLabel" wrapText="true" />
                                <TextArea fx:id="scriptTextArea"
                                          prefHeight="320.0"
                                          style="-fx-font-family: 'Consolas'; -fx-font-size: 13px;"
                                          wrapText="false"
                                          VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>
                                <Button fx:id="saveRuleButton"
                                        mnemonicParsing="false"
                                        onAction="#saveRule"
                                        styleClass="wh-btn, wh-btn-primary"
                                        text="Save Rule" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
