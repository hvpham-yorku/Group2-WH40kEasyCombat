<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="900.0" prefWidth="1500.0" styleClass="game-root" stylesheets="@application.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="eecs2311.group2.wh40k_easycombat.controller.GameUIController">

    <top>
        <HBox spacing="18.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
            </padding>

            <children>
                <VBox minWidth="280.0" spacing="8.0" styleClass="game-player-blue" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="16.0" right="20.0" bottom="16.0" left="20.0" />
                    </padding>
                    <children>
                        <Label fx:id="blueFactionLabel" text="FactionName" wrapText="true">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label text="Phase">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                                <Label fx:id="bluePhaseLabel" text="Command (Active)">
                                    <font>
                                        <Font size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label text="Victory Points">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                                <Label fx:id="blueVPLabel" text="1">
                                    <font>
                                        <Font name="System Bold" size="30.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox alignment="CENTER" minWidth="220.0" prefWidth="260.0" spacing="8.0" styleClass="game-round-panel">
                    <padding>
                        <Insets top="16.0" right="12.0" bottom="16.0" left="12.0" />
                    </padding>
                    <children>
                        <Label text="Round">
                            <font>
                                <Font size="18.0" />
                            </font>
                        </Label>
                        <Label fx:id="roundLabel" styleClass="game-round-number" text="1">
                            <font>
                                <Font name="System Bold" size="38.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox alignment="CENTER_RIGHT" minWidth="280.0" spacing="8.0" styleClass="game-player-red" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="16.0" right="20.0" bottom="16.0" left="20.0" />
                    </padding>
                    <children>
                        <Label fx:id="redFactionLabel" text="FactionName" wrapText="true">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <HBox alignment="CENTER_RIGHT" spacing="8.0">
                            <children>
                                <Label text="Phase">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                                <Label fx:id="redPhaseLabel" text="Command">
                                    <font>
                                        <Font size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="8.0">
                            <children>
                                <Label text="Victory Points">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </Label>
                                <Label fx:id="redVPLabel" text="1">
                                    <font>
                                        <Font name="System Bold" size="30.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>

    <center>
        <GridPane hgap="18.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="0.0" right="18.0" bottom="18.0" left="18.0" />
            </padding>

            <columnConstraints>
                <ColumnConstraints minWidth="280.0" percentWidth="36.0" hgrow="ALWAYS" />
                <ColumnConstraints minWidth="260.0" percentWidth="28.0" hgrow="ALWAYS" />
                <ColumnConstraints minWidth="280.0" percentWidth="36.0" hgrow="ALWAYS" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints vgrow="ALWAYS" />
            </rowConstraints>

            <children>
                <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" pannable="true"
                            styleClass="game-panel-scroll"
                            GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <content>
                        <VBox fillWidth="true" spacing="14.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                            </padding>

                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Command Points">
                                            <font>
                                                <Font size="20.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="blueSubButton" mnemonicParsing="false" onMouseClicked="#blueClickSub"
                                                prefHeight="36.0" prefWidth="40.0" styleClass="wh-btn" text="-" />
                                        <Label fx:id="blueCPLabel" text="2">
                                            <font>
                                                <Font name="System Bold" size="28.0" />
                                            </font>
                                        </Label>
                                        <Button fx:id="bluePlusButton" mnemonicParsing="false" onMouseClicked="#blueClickPlus"
                                                prefHeight="36.0" prefWidth="40.0" styleClass="wh-btn" text="+" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Army">
                                            <font>
                                                <Font size="18.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="blueImportButton" mnemonicParsing="false" onMouseClicked="#blueImport"
                                                prefHeight="36.0" prefWidth="120.0" styleClass="wh-btn" text="Import Army" />
                                    </children>
                                </HBox>

                                <ListView fx:id="blueArmyList" minHeight="0.0" prefHeight="260.0" styleClass="game-list" VBox.vgrow="ALWAYS" />

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Stratagems">
                                            <font>
                                                <Font size="18.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="blueSelectButton" mnemonicParsing="false" onMouseClicked="#blueSelect"
                                                prefHeight="36.0" prefWidth="90.0" styleClass="wh-btn" text="Select" />
                                    </children>
                                </HBox>

                                <ListView fx:id="blueStrategyList" minHeight="0.0" prefHeight="220.0" styleClass="game-list" VBox.vgrow="ALWAYS" />

                                <Label text="Secondary Mission">
                                    <font>
                                        <Font size="18.0" />
                                    </font>
                                </Label>

                                <TableView fx:id="blueMissionTable" minHeight="0.0" prefHeight="190.0" styleClass="game-table" VBox.vgrow="SOMETIMES">
                                    <columns>
                                        <TableColumn fx:id="blueMissionName" prefWidth="220.0" text="Mission" />
                                        <TableColumn fx:id="blueMissionState" prefWidth="90.0" text="State" />
                                    </columns>
                                </TableView>

                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="blueCheckMissionButton" mnemonicParsing="false" onMouseClicked="#blueCheckClicked"
                                                prefHeight="38.0" prefWidth="130.0" styleClass="wh-btn" text="Check Mission" wrapText="true" />
                                        <Button fx:id="blueAbandonMissionButton" mnemonicParsing="false" onMouseClicked="#blueAbandonClicked"
                                                prefHeight="38.0" prefWidth="150.0" styleClass="wh-btn, wh-btn-danger" text="Abandon Mission" wrapText="true" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" pannable="true"
                            styleClass="game-panel-scroll"
                            GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <content>
                        <VBox alignment="TOP_CENTER" fillWidth="true" spacing="16.0" styleClass="game-center-panel">
                            <padding>
                                <Insets top="22.0" right="18.0" bottom="22.0" left="18.0" />
                            </padding>

                            <children>
                                <Label text="Primary Mission">
                                    <font>
                                        <Font size="22.0" />
                                    </font>
                                </Label>

                                <Label fx:id="missionNameLabel" alignment="CENTER"
                                       maxWidth="1.7976931348623157E308"
                                       prefWidth="320.0"
                                       text="MissionName"
                                       textAlignment="CENTER"
                                       wrapText="true">
                                    <font>
                                        <Font name="System Bold Italic" size="22.0" />
                                    </font>
                                </Label>

                                <Label text="Manual Dice">
                                    <font>
                                        <Font size="20.0" />
                                    </font>
                                </Label>

                                <HBox alignment="CENTER" spacing="12.0">
                                    <children>
                                        <Spinner fx:id="virtuaDiceSpinner" editable="true" prefHeight="40.0" prefWidth="120.0" styleClass="game-spinner" />
                                        <Button fx:id="rollButton" mnemonicParsing="false" onMouseClicked="#rollDice"
                                                prefHeight="40.0" prefWidth="90.0" styleClass="wh-btn, wh-btn-primary" text="Roll" />
                                    </children>
                                </HBox>

                                <TextArea fx:id="virtuaDiceBox" minHeight="0.0" prefHeight="320.0" styleClass="game-textarea" wrapText="true" VBox.vgrow="ALWAYS" />

                                <CheckBox fx:id="autoBattleCheckBox" mnemonicParsing="false" onAction="#openAutoBattle" styleClass="game-checkbox" text="Auto Battle">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                </CheckBox>

                                <Button fx:id="nextPhaseButton" mnemonicParsing="false" onAction="#nextPhase"
                                        prefHeight="58.0" prefWidth="220.0" styleClass="wh-btn, wh-btn-primary" text="Next Phase">
                                    <font>
                                        <Font size="22.0" />
                                    </font>
                                </Button>

                                <Button fx:id="battleLogButton" mnemonicParsing="false" onMouseClicked="#openLog"
                                        prefHeight="40.0" prefWidth="180.0" styleClass="wh-btn" text="Battle Log">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Button>

                                <Button fx:id="exitGameButton" mnemonicParsing="false" onMouseClicked="#clickExit"
                                        prefHeight="40.0" prefWidth="180.0" styleClass="wh-btn, wh-btn-danger" text="Exit Game">
                                    <font>
                                        <Font size="16.0" />
                                    </font>
                                </Button>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" pannable="true"
                            styleClass="game-panel-scroll"
                            GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <content>
                        <VBox fillWidth="true" spacing="14.0" styleClass="game-side-panel">
                            <padding>
                                <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                            </padding>

                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Command Points">
                                            <font>
                                                <Font size="20.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="redSubButton" mnemonicParsing="false" onMouseClicked="#redClickSub"
                                                prefHeight="36.0" prefWidth="40.0" styleClass="wh-btn" text="-" />
                                        <Label fx:id="redCPLabel" text="1">
                                            <font>
                                                <Font name="System Bold" size="28.0" />
                                            </font>
                                        </Label>
                                        <Button fx:id="redPlusButton" mnemonicParsing="false" onMouseClicked="#redClickPlus"
                                                prefHeight="36.0" prefWidth="40.0" styleClass="wh-btn" text="+" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Army">
                                            <font>
                                                <Font size="18.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="redImportButton" mnemonicParsing="false" onMouseClicked="#redImport"
                                                prefHeight="36.0" prefWidth="120.0" styleClass="wh-btn" text="Import Army" />
                                    </children>
                                </HBox>

                                <ListView fx:id="redArmyList" minHeight="0.0" prefHeight="260.0" styleClass="game-list" VBox.vgrow="ALWAYS" />

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Stratagems">
                                            <font>
                                                <Font size="18.0" />
                                            </font>
                                        </Label>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="redSelectButton" mnemonicParsing="false" onMouseClicked="#redSelect"
                                                prefHeight="36.0" prefWidth="90.0" styleClass="wh-btn" text="Select" />
                                    </children>
                                </HBox>

                                <ListView fx:id="redStrategyList" minHeight="0.0" prefHeight="220.0" styleClass="game-list" VBox.vgrow="ALWAYS" />

                                <Label text="Secondary Mission">
                                    <font>
                                        <Font size="18.0" />
                                    </font>
                                </Label>

                                <TableView fx:id="redMissionTable" minHeight="0.0" prefHeight="190.0" styleClass="game-table" VBox.vgrow="SOMETIMES">
                                    <columns>
                                        <TableColumn fx:id="redMissionName" prefWidth="220.0" text="Mission" />
                                        <TableColumn fx:id="redState" prefWidth="90.0" text="State" />
                                    </columns>
                                </TableView>

                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                        <Button fx:id="redCheckMissionButton" mnemonicParsing="false" onMouseClicked="#redCheckClicked"
                                                prefHeight="38.0" prefWidth="130.0" styleClass="wh-btn" text="Check Mission" wrapText="true" />
                                        <Button fx:id="redAbandonMissionButton" mnemonicParsing="false" onMouseClicked="#redAbandonClicked"
                                                prefHeight="38.0" prefWidth="150.0" styleClass="wh-btn, wh-btn-danger" text="Abandon Mission" wrapText="true" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </GridPane>
    </center>
</BorderPane>
