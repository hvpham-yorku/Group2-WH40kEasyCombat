<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="800.0" prefWidth="1200.0"
           styleClass="main-root"
           stylesheets="@application.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="eecs2311.group2.wh40k_easycombat.controller.MainUIController">

    <children>
        <VBox alignment="CENTER" fillWidth="true" maxWidth="420.0" spacing="28.0">
            <padding>
                <Insets top="32.0" right="24.0" bottom="32.0" left="24.0" />
            </padding>

            <children>
                <Label styleClass="main-title"
                       alignment="CENTER"
                       maxWidth="1.7976931348623157E308"
                       text="WARHAMMER 40,000"
                       textAlignment="CENTER"
                       wrapText="true" />

                <Label styleClass="main-subtitle"
                       alignment="CENTER"
                       maxWidth="1.7976931348623157E308"
                       text="Easy Combat"
                       textAlignment="CENTER" />

                <VBox alignment="CENTER" fillWidth="true" maxWidth="340.0" spacing="18.0" styleClass="button-panel">
                    <padding>
                        <Insets top="26.0" right="22.0" bottom="26.0" left="22.0" />
                    </padding>

                    <children>
                        <Button fx:id="startButton"
                                maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false"
                                onMouseClicked="#startBtn"
                                prefHeight="58.0"
                                styleClass="wh-btn, wh-btn-primary"
                                text="Start Game" />

                        <Button fx:id="ruleButton"
                                maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false"
                                onMouseClicked="#ruleBtn"
                                prefHeight="58.0"
                                styleClass="wh-btn"
                                text="Datasheets and Rules"
                                wrapText="true" />

                        <Button fx:id="armyButton"
                                maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false"
                                onMouseClicked="#armyBtn"
                                prefHeight="58.0"
                                styleClass="wh-btn"
                                text="Army List" />

                        <Button fx:id="exitButton"
                                maxWidth="1.7976931348623157E308"
                                mnemonicParsing="false"
                                onMouseClicked="#exitBtn"
                                prefHeight="58.0"
                                styleClass="wh-btn, wh-btn-danger"
                                text="Exit" />
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox alignment="TOP_RIGHT"
              prefWidth="360.0"
              maxWidth="360.0"
              spacing="10.0"
              styleClass="main-update-panel"
              StackPane.alignment="CENTER_RIGHT">
            <padding>
                <Insets top="24.0" right="20.0" bottom="24.0" left="20.0" />
            </padding>

            <children>
                <VBox spacing="8.0" styleClass="main-side-card" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
                    </padding>
                    <children>
                        <Label styleClass="main-update-title" text="News" />
                        <ScrollPane fitToWidth="true"
                                    hbarPolicy="NEVER"
                                    styleClass="main-news-scroll"
                                    VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="newsLinksBox" spacing="8.0">
                                    <children>
                                        <Label fx:id="newsStatusLabel"
                                               styleClass="main-update-caption"
                                               text="Loading latest news..." />
                                    </children>
                                </VBox>
                            </content>
                        </ScrollPane>
                        <Hyperlink fx:id="moreNewsLink"
                                   onAction="#openWarhammerNewsPage"
                                   styleClass="main-news-link"
                                   text="More news..." />
                    </children>
                </VBox>

                <Region prefHeight="6.0" />

                <VBox spacing="10.0" styleClass="main-side-card">
                    <padding>
                        <Insets top="14.0" right="14.0" bottom="14.0" left="14.0" />
                    </padding>
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="main-update-title" text="Last Update" />
                                <Label fx:id="lastUpdateLabel"
                                       styleClass="main-update-value"
                                       text="Unknown" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <HBox alignment="CENTER_RIGHT" spacing="4.0">
                                    <children>
                                        <Label styleClass="main-update-caption" text="Update Datas From" />
                                        <Hyperlink fx:id="wahapediaLink"
                                                   onAction="#openWahapediaExport"
                                                   text="Wahapedia" />
                                        <Label styleClass="main-update-caption" text="CSV files" />
                                    </children>
                                </HBox>

                                <Button fx:id="updateButton"
                                        maxWidth="1.7976931348623157E308"
                                        mnemonicParsing="false"
                                        onMouseClicked="#updateDataBtn"
                                        prefHeight="44.0"
                                        styleClass="wh-btn"
                                        text="Update" />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>
